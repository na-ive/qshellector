#!/usr/bin/env bash
# QShellector - QuickShell Configuration Selector
# Auto-detects shells from ~/.config/quickshell/ and provides
# a TUI for switching between them with persistent selection.
#
# Usage:
#   qshellector              - Launch TUI selector
#   qshellector list         - List available shells
#   qshellector status       - Show active shell
#   qshellector switch NAME  - Switch to shell by name
#   qshellector restart      - Restart current shell
#   qshellector fix-tray     - Fix system tray (D-Bus cleanup + restart)
#   qshellector detect-fonts - Re-run font/icon detection for TUI mode
#   qshellector log          - Tail the active shell's log

set -euo pipefail

# ─── Configuration ──────────────────────────────────────────────────────────
QS_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/quickshell"
QSHELLECTOR_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/qshellector"
QSHELLECTOR_ACTIVE="$QSHELLECTOR_DIR/active"
QSHELLECTOR_KEYBINDS="$QSHELLECTOR_DIR/keybinds"
QSHELLECTOR_LOG_FILE="${XDG_CACHE_HOME:-$HOME/.cache}/qshellector/quickshell.log"
HYPR_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/hypr"

# ─── Colors (uses terminal theme colors only) ──────────────────────────────
C_RESET='\033[0m'
C_BOLD='\033[1m'
C_DIM='\033[2m'
C_CYAN='\033[36m'
C_GREEN='\033[32m'
C_YELLOW='\033[33m'
C_MAGENTA='\033[35m'
C_WHITE='\033[97m'
C_ACTIVE='\033[32m'      # Standard terminal green for active indicator

# ─── TUI Mode Detection ────────────────────────────────────────────────────
TUI_MODE="minimal"
if [[ -f "$QSHELLECTOR_DIR/tui_mode" ]]; then
    TUI_MODE="$(cat "$QSHELLECTOR_DIR/tui_mode" 2>/dev/null || echo "minimal")"
fi

# ─── Maximal Mode Styling ──────────────────────────────────────────────────
C_BORDER='\033[2m'           # dim for borders (uses terminal fg)
C_INNER='\033[2m'            # dim for inner panel

# ─── Nerd Font Icons (maximal mode) ─────────────────────────────────────────
ICON_SHELL='󱂬'     # nf-md-bash
ICON_SELECT='❯'    # selection arrow
ICON_RUNNING='●'
ICON_STOPPED='○'

# ─── ASCII Fallbacks (minimal mode) ─────────────────────────────────────────
ASCII_SELECT='>'
ASCII_RUNNING='*'
ASCII_STOPPED=' '

# ─── Figlet Art ─────────────────────────────────────────────────────────────
# "QSHELL" in Unicode block style (maximal mode)
FIGLET_MAX=(
    ' ██████╗ ███████╗██╗  ██╗███████╗██╗     ██╗     '
    '██╔═══██╗██╔════╝██║  ██║██╔════╝██║     ██║     '
    '██║   ██║███████╗███████║█████╗  ██║     ██║     '
    '██║▄▄ ██║╚════██║██╔══██║██╔══╝  ██║     ██║     '
    '╚██████╔╝███████║██║  ██║███████╗███████╗███████╗'
    ' ╚══▀▀═╝ ╚══════╝╚═╝  ╚═╝╚══════╝╚══════╝╚══════╝'
)

# "QSHELL" in pure ASCII art (minimal mode)
FIGLET_MIN=(
    '  ___  ____  _   _ _____ _     _     '
    ' / _ \/ ___|| | | | ____| |   | |    '
    '| | | \___ \| |_| |  _| | |   | |    '
    '| |_| |___) |  _  | |___| |___| |___ '
    ' \__\_\____/|_| |_|_____|_____|_____|'
)

# ─── Helpers ────────────────────────────────────────────────────────────────
die() { echo -e "${C_BOLD}\033[31mError:${C_RESET} $*" >&2; exit 1; }
info() { echo -e "${C_DIM}$*${C_RESET}"; }

ensure_state_dir() {
    mkdir -p "$QSHELLECTOR_DIR"
    mkdir -p "$QSHELLECTOR_KEYBINDS"
}

# Measure visible display width of a string (handles Unicode widths correctly)
vis_width() {
    printf '%s' "$1" | wc -L
}

# Generate a string of N spaces
spaces() {
    printf '%*s' "$1" ''
}

# ─── Shell Detection ────────────────────────────────────────────────────────
# Scans ~/.config/quickshell/ for directories containing shell.qml
# Filters out directories ending in .old
detect_shells() {
    local shells=()
    if [[ ! -d "$QS_CONFIG_DIR" ]]; then
        die "QuickShell config directory not found: $QS_CONFIG_DIR"
    fi

    for dir in "$QS_CONFIG_DIR"/*/; do
        [[ ! -d "$dir" ]] && continue
        local name
        name="$(basename "$dir")"

        # Filter .old directories
        [[ "$name" == *.old ]] && continue

        # Must have shell.qml
        if [[ -f "$dir/shell.qml" ]]; then
            shells+=("$name")
        fi
    done

    if [[ ${#shells[@]} -eq 0 ]]; then
        die "No QuickShell configurations found in $QS_CONFIG_DIR"
    fi

    printf '%s\n' "${shells[@]}" | sort
}

# ─── State Management ───────────────────────────────────────────────────────
get_active_shell() {
    if [[ -f "$QSHELLECTOR_ACTIVE" ]]; then
        cat "$QSHELLECTOR_ACTIVE"
    else
        # Try to detect from running process
        local running
        running=$(pgrep -a -f '\b(quickshell|qs) -c' | sed -E 's/.*(quickshell|qs) -c ([^ ]*).*/\2/' | head -1)
        if [[ -n "$running" ]]; then
            echo "$running"
        else
            echo ""
        fi
    fi
}

set_active_shell() {
    ensure_state_dir
    echo "$1" > "$QSHELLECTOR_ACTIVE"
}

# ─── Keybind Management ─────────────────────────────────────────────────────
# Each shell can have a keybind file at:
#   ~/.config/qshellector/keybinds/<shell_name>.lua
# When switching, we symlink the active keybind file to:
#   ~/.config/hypr/qshellector/active_keybinds.lua
# Which should be required from hyprland.lua
activate_keybinds() {
    local shell_name="$1"
    local keybind_file="$QSHELLECTOR_KEYBINDS/${shell_name}.lua"
    local hypr_qshellector_dir="$HYPR_CONFIG_DIR/qshellector"
    local active_link="$hypr_qshellector_dir/active_keybinds.lua"

    mkdir -p "$hypr_qshellector_dir"

    if [[ -f "$keybind_file" ]]; then
        # Remove old symlink/file
        rm -f "$active_link"
        ln -sf "$keybind_file" "$active_link"
        info "  Keybinds: activated ${shell_name}.lua"
    else
        # No keybind file for this shell — create empty placeholder
        rm -f "$active_link"
        echo "-- QShellector: no custom keybinds for '$shell_name'" > "$active_link"
        info "  Keybinds: no custom file for $shell_name (using empty)"
    fi
}

# ─── Shell Switching ─────────────────────────────────────────────────────────
do_switch() {
    local target="$1"

    # Validate target exists
    if [[ ! -d "$QS_CONFIG_DIR/$target" ]] || [[ ! -f "$QS_CONFIG_DIR/$target/shell.qml" ]]; then
        die "Shell '$target' not found or missing shell.qml"
    fi

    local current
    current=$(get_active_shell)

    if [[ "$current" == "$target" ]]; then
        info "Already running '$target'. Use 'qshellector restart' to restart."
        return 0
    fi

    echo -e "${C_CYAN}Switching:${C_RESET} ${current:-none} → ${C_BOLD}$target${C_RESET}"

    # 1. Kill existing quickshell
    echo -e "  ${C_DIM}Stopping quickshell...${C_RESET}"
    killall qs quickshell 2>/dev/null || true
    sleep 1

    # 2. Update state
    set_active_shell "$target"

    # 3. Activate keybinds
    activate_keybinds "$target"


    # 4. Start new shell
    echo -e "  ${C_DIM}Starting quickshell -c $target...${C_RESET}"
    mkdir -p "$(dirname "$QSHELLECTOR_LOG_FILE")"
    nohup quickshell -c "$target" > "$QSHELLECTOR_LOG_FILE" 2>&1 &

    echo -e "${C_GREEN}✓${C_RESET} Switched to ${C_BOLD}$target${C_RESET}"
}

do_restart() {
    local current
    current=$(get_active_shell)

    if [[ -z "$current" ]]; then
        die "No active shell to restart. Use 'qshellector switch <name>' first."
    fi

    echo -e "${C_CYAN}Restarting:${C_RESET} ${C_BOLD}$current${C_RESET}"

    # Kill existing
    killall qs quickshell 2>/dev/null || true
    sleep 1

    # Start fresh
    mkdir -p "$(dirname "$QSHELLECTOR_LOG_FILE")"
    nohup quickshell -c "$current" > "$QSHELLECTOR_LOG_FILE" 2>&1 &

    echo -e "${C_GREEN}✓${C_RESET} Restarted ${C_BOLD}$current${C_RESET}"
}

do_fix_tray() {
    local current
    current=$(get_active_shell)

    if [[ -z "$current" ]]; then
        die "No active shell. Use 'qshellector switch <name>' first."
    fi

    echo -e "${C_YELLOW}Fixing tray:${C_RESET} ${C_BOLD}$current${C_RESET}"

    # 1. Kill existing quickshell
    killall qs quickshell 2>/dev/null || true

    # 2. Clean up D-Bus StatusNotifierWatcher
    local watcher_pid
    watcher_pid=$(dbus-send --session --dest=org.freedesktop.DBus --type=method_call \
        --print-reply /org/freedesktop/DBus org.freedesktop.DBus.GetConnectionUnixProcessID \
        string:"org.kde.StatusNotifierWatcher" 2>/dev/null | grep uint32 | awk '{print $2}')

    if [[ -n "$watcher_pid" ]]; then
        echo -e "  ${C_DIM}Cleaning zombie tray watcher (PID: $watcher_pid)...${C_RESET}"
        kill -9 "$watcher_pid" 2>/dev/null || true
        sleep 0.5
    fi

    # 3. Wait for cleanup
    sleep 1

    # 4. Start quickshell
    mkdir -p "$(dirname "$QSHELLECTOR_LOG_FILE")"
    nohup quickshell -c "$current" > "$QSHELLECTOR_LOG_FILE" 2>&1 &

    # 5. Wait for init
    sleep 2

    # 6. Force re-registration
    dbus-send --type=signal / org.freedesktop.DBus.NameOwnerChanged \
        string:"org.kde.StatusNotifierWatcher" string:":1.dummy" string:":1.dummy2"

    echo -e "${C_GREEN}✓${C_RESET} Tray fixed for ${C_BOLD}$current${C_RESET}"
}

do_log() {
    if [[ -f "$QSHELLECTOR_LOG_FILE" ]]; then
        echo -e "${C_CYAN}Watching log at: ${C_DIM}$QSHELLECTOR_LOG_FILE${C_RESET}"
        echo -e "${C_DIM}(Press Ctrl+C to stop)${C_RESET}"
        tail -f "$QSHELLECTOR_LOG_FILE"
    else
        die "Log file not found at $QSHELLECTOR_LOG_FILE. Has any shell been started?"
    fi
}

# ─── Check Process Status ───────────────────────────────────────────────────
is_shell_running() {
    local name="$1"
    pgrep -f "(quickshell|qs) -c $name" > /dev/null 2>&1
}

# ─── Width & Centering ──────────────────────────────────────────────────────
# Pre-compute icon display widths at startup (measured, not assumed)
ICON_SHELL_W=0
ICON_SELECT_W=0
ICON_RUNNING_W=0

precompute_icon_widths() {
    ICON_SHELL_W=$(vis_width "$ICON_SHELL")
    ICON_SELECT_W=$(vis_width "$ICON_SELECT")
    ICON_RUNNING_W=$(vis_width "$ICON_RUNNING")
}

calc_layout() {
    local -n _cl_shells=$1
    local term_width
    term_width=$(tput cols 2>/dev/null || echo 80)
    local term_height
    term_height=$(tput lines 2>/dev/null || echo 24)

    # Calculate scrolling window size based on available terminal height
    local num_shells=${#_cl_shells[@]}
    local non_list_h=0
    if [[ "$TUI_MODE" == "maximal" ]]; then
        non_list_h=17  # Headers, footers, and padding lines
    else
        non_list_h=13
    fi
    local max_list=$(( term_height - non_list_h - 2 ))
    (( max_list > 5 )) && max_list=5
    (( max_list < 3 )) && max_list=3

    local display_count=$num_shells
    if (( num_shells > max_list )); then
        display_count=$max_list
    fi

    # Find longest shell name
    local max_name=0
    for name in "${_cl_shells[@]}"; do
        if (( ${#name} > max_name )); then
            max_name=${#name}
        fi
    done

    local box_w
    if [[ "$TUI_MODE" == "maximal" ]]; then
        precompute_icon_widths

        # Inner line: "  ❯  󱂬  name          ● running "
        local inner_content_w=$(( 2 + ICON_SELECT_W + 2 + ICON_SHELL_W + 2 + max_name + 4 + ICON_RUNNING_W + 8 + 1 ))

        # Figlet display width
        local figlet_w
        figlet_w=$(vis_width "${FIGLET_MAX[0]}")

        # Box width
        local from_figlet=$(( figlet_w + 6 ))
        local from_inner=$(( inner_content_w + 8 ))
        box_w=$(( from_figlet > from_inner ? from_figlet : from_inner ))

        (( box_w < 56 )) && box_w=56
        (( box_w > term_width - 4 )) && box_w=$(( term_width - 4 ))
    else
        local figlet_w
        figlet_w=$(vis_width "${FIGLET_MIN[0]}")
        box_w=$(( max_name + 28 ))
        if (( figlet_w + 4 > box_w )); then
            box_w=$(( figlet_w + 4 ))
        fi
        (( box_w < 42 )) && box_w=42
        (( box_w > term_width - 2 )) && box_w=$(( term_width - 2 ))
    fi

    # Centering width calculation
    local total_w
    if [[ "$TUI_MODE" == "maximal" ]]; then
        total_w=$(( box_w + 2 ))  # box content + left│ + right│
    else
        total_w=$box_w
    fi
    local left_pad=$(( (term_width - total_w) / 2 ))
    (( left_pad < 0 )) && left_pad=0

    # Vertical centering padding
    local content_h=$(( non_list_h + display_count ))
    local top_pad=$(( (term_height - content_h) / 2 ))
    (( top_pad < 0 )) && top_pad=0

    # Export results
    BOX_W=$box_w
    L_PAD="$(spaces "$left_pad")"
    T_PAD="$top_pad"
    DISPLAY_COUNT="$display_count"
}

# ─── Box Drawing Helpers (maximal mode) ─────────────────────────────────────
box_top() {
    local w=$1
    printf "${L_PAD}${C_BORDER}╭"
    printf '─%.0s' $(seq 1 "$w")
    printf "╮${C_RESET}\n"
}

box_bottom() {
    local w=$1
    printf "${L_PAD}${C_BORDER}╰"
    printf '─%.0s' $(seq 1 "$w")
    printf "╯${C_RESET}\n"
}

box_empty() {
    local w=$1
    printf "${L_PAD}${C_BORDER}│${C_RESET}"
    printf '%*s' "$w" ''
    printf "${C_BORDER}│${C_RESET}\n"
}

# Print a line inside the outer box. content_w = visible columns of content.
box_line() {
    local w=$1
    local content="$2"
    local content_w=$3
    local padding=$(( w - content_w ))
    printf "${L_PAD}${C_BORDER}│${C_RESET}"
    printf '%b' "$content"
    (( padding > 0 )) && printf '%*s' "$padding" ''
    printf "${C_BORDER}│${C_RESET}\n"
}

# Inner panel borders
inner_top() {
    local w=$1
    local scroll_up=${2:-false}
    local pad=3
    local inner_w=$(( w - pad * 2 ))
    local lines_w=$(( inner_w - 2 ))
    printf "${L_PAD}${C_BORDER}│${C_RESET}"
    spaces "$pad"
    printf "${C_INNER}┌"
    
    if [[ "$scroll_up" == true ]]; then
        local left=$(( (lines_w - 3) / 2 ))
        local right=$(( lines_w - 3 - left ))
        for (( i=0; i<left; i++ )); do printf '─'; done
        printf " ${C_CYAN}▲${C_RESET}${C_INNER} "
        for (( i=0; i<right; i++ )); do printf '─'; done
    else
        for (( i=0; i<lines_w; i++ )); do printf '─'; done
    fi
    
    printf "┐${C_RESET}"
    spaces "$pad"
    printf "${C_BORDER}│${C_RESET}\n"
}

inner_bottom() {
    local w=$1
    local scroll_down=${2:-false}
    local pad=3
    local inner_w=$(( w - pad * 2 ))
    local lines_w=$(( inner_w - 2 ))
    printf "${L_PAD}${C_BORDER}│${C_RESET}"
    spaces "$pad"
    printf "${C_INNER}└"
    
    if [[ "$scroll_down" == true ]]; then
        local left=$(( (lines_w - 3) / 2 ))
        local right=$(( lines_w - 3 - left ))
        for (( i=0; i<left; i++ )); do printf '─'; done
        printf " ${C_CYAN}▼${C_RESET}${C_INNER} "
        for (( i=0; i<right; i++ )); do printf '─'; done
    else
        for (( i=0; i<lines_w; i++ )); do printf '─'; done
    fi
    
    printf "┘${C_RESET}"
    spaces "$pad"
    printf "${C_BORDER}│${C_RESET}\n"
}

inner_line() {
    local w=$1
    local content="$2"
    local content_w=$3
    local pad=3
    local inner_w=$(( w - pad * 2 ))
    local content_space=$(( inner_w - 2 ))
    local right_pad=$(( content_space - content_w ))

    printf "${L_PAD}${C_BORDER}│${C_RESET}"
    spaces "$pad"
    printf "${C_INNER}│${C_RESET}"
    printf '%b' "$content"
    (( right_pad > 0 )) && spaces "$right_pad"
    printf "${C_INNER}│${C_RESET}"
    spaces "$pad"
    printf "${C_BORDER}│${C_RESET}\n"
}

# ─── TUI: Maximal Mode ─────────────────────────────────────────────────────
draw_tui_max() {
    local -n _shells_max=$1
    local selected=$2
    local active=$3
    local w=$BOX_W

    printf '\033[H'
    (( T_PAD > 0 )) && printf '\033[K\n%.0s' $(seq 1 "$T_PAD")

    # ── Outer border top
    box_top "$w"
    box_empty "$w"

    # ── Figlet header (terminal cyan, no forced gradient)
    for i in "${!FIGLET_MAX[@]}"; do
        local figlet_line="${FIGLET_MAX[$i]}"
        local figlet_vis_w
        figlet_vis_w=$(vis_width "$figlet_line")
        local padded="   ${figlet_line}"
        local padded_vis_w=$(( figlet_vis_w + 3 ))
        box_line "$w" "${C_CYAN}${C_BOLD}${padded}${C_RESET}" "$padded_vis_w"
    done

    # ── Subtitle
    local subtitle="   QuickShell Config Selector"
    box_line "$w" "${C_DIM}${subtitle}${C_RESET}" "${#subtitle}"
    box_empty "$w"

    # ── Inner panel
    local has_more_up=false
    local has_more_down=false
    local start_idx=$(( selected - DISPLAY_COUNT / 2 ))
    (( start_idx < 0 )) && start_idx=0
    if (( start_idx + DISPLAY_COUNT > ${#_shells_max[@]} )); then
        start_idx=$(( ${#_shells_max[@]} - DISPLAY_COUNT ))
        (( start_idx < 0 )) && start_idx=0
    fi
    local end_idx=$(( start_idx + DISPLAY_COUNT - 1 ))
    (( start_idx > 0 )) && has_more_up=true
    (( end_idx < ${#_shells_max[@]} - 1 )) && has_more_down=true

    inner_top "$w" "$has_more_up"

    local pad=3
    local inner_w=$(( w - pad * 2 ))


    for i in $(seq "$start_idx" "$end_idx"); do
        local name="${_shells_max[$i]}"
        local is_active=false
        local is_running=false

        [[ "$name" == "$active" ]] && is_active=true
        is_shell_running "$name" && is_running=true

        # Build status indicator
        local status_str=""
        local status_vis_w=0
        if [[ "$is_active" == true ]]; then
            if [[ "$is_running" == true ]]; then
                status_str="${C_ACTIVE}${ICON_RUNNING} running${C_RESET}"
                status_vis_w=$(( ICON_RUNNING_W + 8 ))  # icon + " running"
            else
                status_str="${C_DIM}${ICON_STOPPED} stopped${C_RESET}"
                status_vis_w=$(( ICON_RUNNING_W + 8 ))
            fi
        fi

        # Build prefix: "  ❯  " or "     "
        local prefix prefix_vis_w
        if [[ $i -eq $selected ]]; then
            # We ONLY use the cyan bold icon here, no background color
            prefix="  ${C_CYAN}${C_BOLD}${ICON_SELECT}${C_RESET}  "
            prefix_vis_w=$(( 2 + ICON_SELECT_W + 2 ))
        else
            prefix_vis_w=$(( 2 + ICON_SELECT_W + 2 ))
            prefix="$(spaces "$prefix_vis_w")"
        fi

        # Icon + name
        local icon_str="${C_CYAN}${ICON_SHELL}${C_RESET}  "
        local icon_vis_w=$(( ICON_SHELL_W + 2 ))

        local name_str
        if [[ $i -eq $selected ]]; then
            name_str="${C_WHITE}${C_BOLD}${name}${C_RESET}"
        else
            name_str="${C_DIM}${name}${C_RESET}"
        fi
        local name_vis_w=${#name}

        local total_vis_w=$(( prefix_vis_w + icon_vis_w + name_vis_w ))

        # Assemble line
        local line_content line_vis_w
        if [[ -n "$status_str" ]]; then
            local inner_content_space=$(( inner_w - 2 ))
            local gap=$(( inner_content_space - total_vis_w - status_vis_w ))
            (( gap < 2 )) && gap=2
            line_content="${prefix}${icon_str}${name_str}$(spaces "$gap")${status_str}"
            line_vis_w=$(( total_vis_w + gap + status_vis_w ))
        else
            line_content="${prefix}${icon_str}${name_str}"
            line_vis_w=$total_vis_w
        fi

        # Always use inner_line (no background highlights)
        inner_line "$w" "$line_content" "$line_vis_w"
    done

    inner_bottom "$w" "$has_more_down"
    box_empty "$w"

    # ── Footer
    local footer1="   ↑↓ navigate · ⏎ select · r restart"
    local footer1_vis_w
    footer1_vis_w=$(vis_width "$footer1")
    local footer2="   f fix-tray · q quit"
    box_line "$w" "${C_DIM}${footer1}${C_RESET}" "$footer1_vis_w"
    box_line "$w" "${C_DIM}${footer2}${C_RESET}" "${#footer2}"
    box_empty "$w"

    box_bottom "$w"
    printf '\033[J'
}

# ─── TUI: Minimal Mode ─────────────────────────────────────────────────────
draw_tui_min() {
    local -n _shells_min=$1
    local selected=$2
    local active=$3
    local w=$BOX_W

    printf '\033[H'
    (( T_PAD > 0 )) && printf '\033[K\n%.0s' $(seq 1 "$T_PAD")

    # Center the content
    echo ""

    # ── Figlet header (centered)
    for line in "${FIGLET_MIN[@]}"; do
        local line_w
        line_w=$(vis_width "$line")
        local line_pad=$(( (w - line_w) / 2 ))
        (( line_pad < 0 )) && line_pad=0
        printf "${L_PAD}"
        spaces "$line_pad"
        echo -e "${C_BOLD}${C_CYAN}${line}${C_RESET}"
    done
    echo ""

    # ── Subtitle (centered)
    local sub="QuickShell Config Selector"
    local sub_pad=$(( (w - ${#sub}) / 2 ))
    (( sub_pad < 0 )) && sub_pad=0
    printf "${L_PAD}"
    spaces "$sub_pad"
    echo -e "${C_DIM}${sub}${C_RESET}"
    echo ""


    local has_more_up=false
    local has_more_down=false
    (( start_idx > 0 )) && has_more_up=true
    (( end_idx < ${#_shells_min[@]} - 1 )) && has_more_down=true

    if [[ "$has_more_up" == true ]]; then
        printf "${L_PAD}   "
        echo -e "${C_CYAN}  ▲${C_RESET}"
    else
        echo ""
    fi

    # ── Shell list
    for i in $(seq "$start_idx" "$end_idx"); do
        local name="${_shells_min[$i]}"
        local num=$(( i + 1 ))
        local is_active=false
        local is_running=false

        [[ "$name" == "$active" ]] && is_active=true
        is_shell_running "$name" && is_running=true

        # Build status
        local status_str=""
        if [[ "$is_active" == true ]]; then
            if [[ "$is_running" == true ]]; then
                status_str="${C_ACTIVE}${ASCII_RUNNING} running${C_RESET}"
            else
                status_str="${C_DIM}  stopped${C_RESET}"
            fi
        fi

        # Build line
        local prefix
        if [[ $i -eq $selected ]]; then
            prefix="${C_BOLD}${C_CYAN}${ASCII_SELECT}${C_RESET} "
        else
            prefix="  "
        fi

        local name_str
        if [[ $i -eq $selected ]]; then
            name_str="${C_BOLD}${C_WHITE}${num}  ${name}${C_RESET}"
        else
            name_str="${C_DIM}${num}${C_RESET}  ${name}"
        fi

        printf "${L_PAD}   "
        if [[ -n "$status_str" ]]; then
            local name_part_len=$(( 3 + ${#name} ))
            local gap=$(( w - 5 - name_part_len - 9 ))
            (( gap < 2 )) && gap=2
            echo -e "${prefix}${name_str}$(spaces "$gap")${status_str}"
        else
            echo -e "${prefix}${name_str}"
        fi
    done

    if [[ "$has_more_down" == true ]]; then
        printf "${L_PAD}   "
        echo -e "${C_CYAN}  ▼${C_RESET}"
    else
        echo ""
    fi

    # ── Footer (centered)
    printf "${L_PAD}   "
    echo -e "${C_DIM}Up/Dn navigate  Enter select  r restart${C_RESET}"
    printf "${L_PAD}   "
    echo -e "${C_DIM}f fix-tray  q quit${C_RESET}"
    echo ""
    printf '\033[J'
}

# ─── TUI Dispatcher ────────────────────────────────────────────────────────
draw_tui() {
    if [[ "$TUI_MODE" == "maximal" ]]; then
        draw_tui_max "$@"
    else
        draw_tui_min "$@"
    fi
}

run_tui() {
    local shells_str
    shells_str=$(detect_shells)
    local shells=()
    while IFS= read -r line; do
        shells+=("$line")
    done <<< "$shells_str"

    local count=${#shells[@]}
    local selected=0
    local active
    active=$(get_active_shell)

    # Pre-select active shell
    for i in "${!shells[@]}"; do
        if [[ "${shells[$i]}" == "$active" ]]; then
            selected=$i
            break
        fi
    done

    # Calculate layout (sets BOX_W, L_PAD, T_PAD, DISPLAY_COUNT)
    calc_layout shells

    # Switch to alternate screen, hide cursor
    printf '\033[?1049h\033[?25l'
    # Clear screen initially
    printf '\033[2J'
    # Restore cursor and main screen on exit
    trap 'printf "\033[?25h\033[?1049l"; stty sane 2>/dev/null' EXIT INT TERM

    # Switch to raw mode
    stty -echo -icanon min 1 time 0 2>/dev/null

    while true; do
        draw_tui shells "$selected" "$active"

        # Read input
        local key
        IFS= read -rsn1 key

        case "$key" in
            $'\x1b')
                # Escape sequence — read more
                local seq
                IFS= read -rsn2 -t 0.1 seq || true
                case "$seq" in
                    '[A') # Up arrow
                        if ((selected > 0)); then ((selected--)) || true; fi
                        ;;
                    '[B') # Down arrow
                        if ((selected < count - 1)); then ((selected++)) || true; fi
                        ;;
                    '') # Bare Escape
                        break
                        ;;
                esac
                ;;
            'q'|'Q')
                break
                ;;
            'r'|'R')
                # Restore terminal before action
                stty sane 2>/dev/null
                printf '\033[?25h'
                printf '\033[2J\033[H'
                do_restart
                exit 0
                ;;
            'f'|'F')
                stty sane 2>/dev/null
                printf '\033[?25h'
                printf '\033[2J\033[H'
                do_fix_tray
                exit 0
                ;;
            '') # Enter
                stty sane 2>/dev/null
                printf '\033[?25h'
                printf '\033[2J\033[H'
                do_switch "${shells[$selected]}"
                exit 0
                ;;
            [1-9])
                local idx=$((key - 1))
                if ((idx < count)); then
                    stty sane 2>/dev/null
                    printf '\033[?25h'
                    printf '\033[2J\033[H'
                    do_switch "${shells[$idx]}"
                    exit 0
                fi
                ;;
            'k'|'K') # vim-style up
                ((selected > 0)) && ((selected--))
                ;;
            'j'|'J') # vim-style down
                ((selected < count - 1)) && ((selected++))
                ;;
        esac
    done

    # Cleanup
    printf '\033[2J\033[H'
    stty sane 2>/dev/null
    printf '\033[?25h'
}

# ─── Font Detection ────────────────────────────────────────────────────────
cmd_detect_fonts() {
    echo -e ""
    echo -e "${C_BOLD}${C_CYAN}QShellector — Font Detection${C_RESET}"
    echo -e ""
    echo -e "  This checks if your terminal supports Nerd Font icons"
    echo -e "  and Unicode box-drawing characters."
    echo -e ""
    echo -e "  ${C_BOLD}Test line:${C_RESET}  󰆍 󱂬  ╭─╮ │ ╰─╯  ❯ ● ○"
    echo -e ""
    echo -e "  If the line above shows ${C_BOLD}icons, arrows, and borders${C_RESET}"
    echo -e "  cleanly (no boxes, no missing glyphs), answer ${C_GREEN}y${C_RESET}."
    echo -e ""
    echo -e "  If you see ${C_YELLOW}empty rectangles${C_RESET} or ${C_YELLOW}question marks${C_RESET},"
    echo -e "  answer ${C_YELLOW}n${C_RESET} for the clean ASCII mode."
    echo -e ""

    read -p "  Do the icons and borders display correctly? [y/N] " -n 1 -r
    echo ""

    ensure_state_dir

    if [[ $REPLY =~ ^[Yy]$ ]]; then
        echo "maximal" > "$QSHELLECTOR_DIR/tui_mode"
        TUI_MODE="maximal"
        echo -e ""
        echo -e "  ${C_GREEN}✓${C_RESET} TUI mode set to ${C_BOLD}maximal${C_RESET} (borders + icons)"
    else
        echo "minimal" > "$QSHELLECTOR_DIR/tui_mode"
        TUI_MODE="minimal"
        echo -e ""
        echo -e "  ${C_GREEN}✓${C_RESET} TUI mode set to ${C_BOLD}minimal${C_RESET} (clean ASCII)"
    fi

    echo -e "  ${C_DIM}Saved to: $QSHELLECTOR_DIR/tui_mode${C_RESET}"
    echo -e "  ${C_DIM}Run 'qshellector detect-fonts' to change later.${C_RESET}"
    echo -e ""
}

# ─── CLI Commands ───────────────────────────────────────────────────────────
cmd_list() {
    local shells_str
    shells_str=$(detect_shells)
    local active
    active=$(get_active_shell)

    echo -e "${C_BOLD}Available QuickShell configurations:${C_RESET}"
    echo ""

    while IFS= read -r name; do
        if [[ "$name" == "$active" ]]; then
            echo -e "  ${C_ACTIVE}●${C_RESET} ${C_BOLD}$name${C_RESET}"
        else
            echo -e "  ${C_DIM}○${C_RESET} $name"
        fi
    done <<< "$shells_str"

    echo ""
}

cmd_status() {
    local active
    active=$(get_active_shell)

    if [[ -n "$active" ]]; then
        echo -e "${C_BOLD}Active shell:${C_RESET} ${C_GREEN}$active${C_RESET}"

        # Check if actually running
        if pgrep -f "quickshell -c $active" > /dev/null 2>&1; then
            echo -e "${C_BOLD}Status:${C_RESET} ${C_GREEN}running${C_RESET}"
        else
            echo -e "${C_BOLD}Status:${C_RESET} ${C_YELLOW}not running${C_RESET}"
        fi
    else
        echo -e "${C_BOLD}Active shell:${C_RESET} ${C_DIM}none${C_RESET}"
    fi
}

cmd_help() {
    echo -e "${C_BOLD}${C_CYAN}QShellector${C_RESET} - QuickShell Config Selector"
    echo ""
    echo -e "${C_BOLD}Usage:${C_RESET}"
    echo "  qshellector              Launch TUI selector"
    echo "  qshellector list         List available shells"
    echo "  qshellector status       Show active shell"
    echo "  qshellector switch NAME  Switch to shell by name"
    echo "  qshellector restart      Restart current shell"
    echo "  qshellector fix-tray     Fix system tray (D-Bus cleanup)"
    echo "  qshellector detect-fonts Re-run font/icon detection for TUI mode"
    echo "  qshellector log          Tail the active shell's log"
    echo "  qshellector help         Show this help"
    echo ""
    echo -e "${C_BOLD}TUI Controls:${C_RESET}"
    echo "  ↑↓ / j k    Navigate"
    echo "  Enter        Select and switch"
    echo "  1-9          Quick select by number"
    echo "  r            Restart current shell"
    echo "  f            Fix tray"
    echo "  q / Escape   Quit"
    echo ""
    echo -e "${C_BOLD}Keybinds:${C_RESET}"
    echo "  Per-shell keybind files live in:"
    echo "  ~/.config/qshellector/keybinds/<shell_name>.lua"
    echo ""
    echo "  Active keybinds are symlinked to:"
    echo "  ~/.config/hypr/qshellector/active_keybinds.lua"
    echo ""
    echo -e "${C_BOLD}TUI Mode:${C_RESET} ${TUI_MODE}"
    echo "  Run 'qshellector detect-fonts' to change."
}

# ─── Main ───────────────────────────────────────────────────────────────────
main() {
    ensure_state_dir

    case "${1:-}" in
        ""|"tui")
            run_tui
            ;;
        "list"|"ls")
            cmd_list
            ;;
        "status"|"st")
            cmd_status
            ;;
        "switch"|"sw")
            [[ -z "${2:-}" ]] && die "Usage: qshellector switch <name>"
            do_switch "$2"
            ;;
        "restart"|"rs")
            do_restart
            ;;
        "fix-tray"|"ft")
            do_fix_tray
            ;;
        "detect-fonts"|"df")
            cmd_detect_fonts
            ;;
        "log")
            do_log
            ;;
        "help"|"-h"|"--help")
            cmd_help
            ;;
        *)
            die "Unknown command: $1\nRun 'qshellector help' for usage."
            ;;
    esac
}

main "$@"
